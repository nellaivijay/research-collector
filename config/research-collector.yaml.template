# Research-Collector Configuration Template
# Copy this file to research-collector.yaml and customize for your needs

sources:
  academic:
    pubmed: true
    crossref: true
    semantic_scholar: true
    paperswithcode: true
    arxiv: true
    inspire_hep: true  # High-energy physics literature database
  
  professional:
    stackoverflow: true
    github: true
    kaggle: true  # Requires KAGGLE_USERNAME and KAGGLE_KEY
    devto: false
    hashnode: false
  
  social:
    reddit: true  # Requires REDDIT_CLIENT_ID, REDDIT_CLIENT_SECRET, REDDIT_USER_AGENT
    hackernews: true
    bluesky: false
    threads: false
  
  news:
    gdelt: true  # Health check skipped due to large file streaming requirements
    newsapi: false  # Requires NEWSAPI_API_KEY

time_ranges:
  default: 7
  quick: 3
  standard: 15
  deep: 30
  historical: 90
  extended: 365

exports:
  default: markdown
  directory: ~/research_outputs
  include_metadata: true

scoring:
  weights:
    relevance: 0.4
    recency: 0.3
    engagement: 0.3
  
  # Preferred researchers/collaborators for author boosting
  # Papers by these researchers will receive a score boost
  preferred_researchers:
    # - "Geoffrey Hinton"
    # - "Yann LeCun"
    # - "Yoshua Bengio"
    # - "Andrew Ng"
    # Add your preferred researchers here
  
  # Domain-specific keyword weights for enhanced relevance scoring
  # Higher weights = more important for your research domain
  keyword_weights:
    # AI/ML Core Concepts
    "transformer": 5
    "attention mechanism": 5
    "neural network": 4
    "deep learning": 4
    "machine learning": 3
    
    # LLM Specific
    "large language model": 6
    "GPT": 5
    "LLM": 5
    "foundation model": 5
    "parameter-efficient": 4
    "fine-tuning": 4
    
    # AGI/Advanced AI
    "artificial general intelligence": 6
    "AGI": 5
    "consciousness": 4
    "reasoning": 4
    "planning": 3
    
    # Training Techniques
    "reinforcement learning": 4
    "supervised learning": 3
    "self-supervised": 4
    "transfer learning": 3
    "few-shot learning": 4
    "zero-shot": 4
    
    # Architecture
    "architecture": 3
    "scaling laws": 5
    "emergent behavior": 4
    "capabilities": 3

# Predefined research topics with corresponding keywords and priorities
# Customize or add your own topics here
predefined_topics:
  agi:
    name: "Artificial General Intelligence"
    priority: "high"  # high, medium, low
    description: "Research on human-level AI and general intelligence"
    keywords:
      - "artificial general intelligence"
      - "AGI"
      - "general AI"
      - "human-level AI"
      - "strong AI"
      - "universal AI"
  
  aci:
    name: "Artificial Conscious Intelligence"
    priority: "medium"
    description: "Research on machine consciousness and sentient AI"
    keywords:
      - "artificial consciousness"
      - "machine consciousness"
      - "AI consciousness"
      - "sentient AI"
      - "conscious AI"
      - "ACI"
  
  asi:
    name: "Artificial Super Intelligence"
    priority: "medium"
    description: "Research on superintelligent AI systems"
    keywords:
      - "artificial super intelligence"
      - "superintelligent AI"
      - "ASI"
      - "superintelligence"
      - "beyond human AI"
  
  ani:
    name: "Artificial Narrow Intelligence"
    priority: "low"
    description: "Research on specialized, task-specific AI systems"
    keywords:
      - "artificial narrow intelligence"
      - "weak AI"
      - "ANI"
      - "specialized AI"
      - "task-specific AI"
      - "narrow AI"
  
  ml:
    name: "Machine Learning"
    priority: "high"
    description: "Core machine learning research and algorithms"
    keywords:
      - "machine learning"
      - "ML"
      - "deep learning"
      - "neural networks"
      - "supervised learning"
      - "unsupervised learning"
      - "reinforcement learning"
  
  llm:
    name: "Large Language Models"
    priority: "high"
    description: "Research on large language models and foundation models"
    keywords:
      - "large language models"
      - "LLM"
      - "language models"
      - "GPT"
      - "transformer models"
      - "foundation models"
  
  # Add your custom topics here
  # example:
  # custom_topic:
  #   name: "Your Custom Topic"
  #   priority: "medium"
  #   description: "Description of your research interest"
  #   keywords:
  #     - "keyword1"
  #     - "keyword2"
  #     - "keyword3"

# Optional API keys for enhanced rate limits
# Set these as environment variables instead of hardcoding
api_keys:
  # pubmed: ${PUBMED_API_KEY}
  # crossref: ${CROSSREF_API_KEY}
  # semantic_scholar: ${SEMANTIC_SCHOLAR_API_KEY}
  # newsapi: ${NEWSAPI_API_KEY}
  # stackexchange: ${STACKEXCHANGE_API_KEY}
  # github: ${GITHUB_TOKEN}
  # reddit: ${REDDIT_CLIENT_ID}
  # reddit_secret: ${REDDIT_CLIENT_SECRET}
  # reddit_user_agent: ${REDDIT_USER_AGENT}
  # kaggle_username: ${KAGGLE_USERNAME}
  # kaggle_key: ${KAGGLE_KEY}

# Advanced settings
advanced:
  max_results_per_source: 100
  clustering_similarity_threshold: 0.85
  enable_caching: true
  cache_ttl_hours: 24
  enable_seen_papers_cache: true
  seen_papers_cache_ttl_days: 30
  seen_papers_cache_path: /tmp/seen_papers.json
  enable_fulltext_extraction: false  # Resource-intensive, enable for better similarity scoring