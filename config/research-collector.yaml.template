# Optional API keys for enhanced rate limits
# Set these as environment variables instead of hardcoding
api_keys:
  # pubmed: ${PUBMED_API_KEY}
  # crossref: ${CROSSREF_API_KEY}
  # semantic_scholar: ${SEMANTIC_SCHOLAR_API_KEY}
  # newsapi: ${NEWSAPI_API_KEY}
  # stackexchange: ${STACKEXCHANGE_API_KEY}
  # github: ${GITHUB_TOKEN}
  # reddit: ${REDDIT_CLIENT_ID}
  # reddit_secret: ${REDDIT_CLIENT_SECRET}
  # reddit_user_agent: ${REDDIT_USER_AGENT}
  # kaggle_username: ${KAGGLE_USERNAME}
  # kaggle_key: ${KAGGLE_KEY}

# Advanced settings
advanced:
  max_results_per_source: 100
  clustering_similarity_threshold: 0.85
  enable_caching: true
  cache_ttl_hours: 24
  enable_seen_papers_cache: true
  seen_papers_cache_ttl_days: 30
  seen_papers_cache_path: /tmp/seen_papers.json
  enable_fulltext_extraction: false  # Resource-intensive, enable for better similarity scoring